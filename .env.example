# Supabase (required)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service_role secret key>

# Session signing (required — generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=<random string>

# URLs — set these to your public domain when deploying to a server
FRONTEND_URL=http://localhost:3042
GOOGLE_REDIRECT_URI=http://localhost:8042/oauth/callback
NEXT_PUBLIC_API_URL=http://localhost:8042

# OAuth transport — set to 0 when using HTTPS in production
OAUTHLIB_INSECURE_TRANSPORT=1

# Session cookie settings.
# For different public domains such as Cloudflare Pages + Railway, use:
# SESSION_COOKIE_SAMESITE=none
# SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=0

# Google OAuth credentials.json — for PaaS (Railway, Render) where you can't mount files.
# Generate with: base64 -i credentials.json | tr -d '\n'
GOOGLE_CREDENTIALS_JSON=

# LLM — taste profile pipeline
OPENROUTER_API_KEY=sk-or-v1-...
# Check exact model slug at openrouter.ai/models — search "minimax"
OPENROUTER_MODEL=minimax/minimax-m1
EMBEDDING_PROVIDER=openrouter
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSIONS=768

# Optional local-only embedding provider fallback
OLLAMA_HOST=http://localhost:11434

# msgvault pipeline
MSGVAULT_ACCOUNT=your@gmail.com
MSGVAULT_SEARCH_MODE=fts

# Port overrides (optional)
# BACKEND_PORT=8042
# FRONTEND_PORT=3042
# OLLAMA_PORT=11434
